# ── Aalirah API — environment template ──────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# MongoDB Atlas connection string. Paste yours here.
# Use a dedicated DB user with least privilege (readWrite on this DB only),
# a strong password, and lock Atlas Network Access to your server's IP.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/aalirah?retryWrites=true&w=majority

# Port the API listens on.
PORT=4000

# Comma-separated browser origins allowed to call the API (CORS).
# Add your production domain when you deploy.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Bearer token protecting the moderation/admin endpoints.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace-with-a-long-random-token

# Signs customer session JWTs. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Hold new reviews for moderation (false) or publish immediately (true).
AUTO_APPROVE=false

# Set to "production" when deploying.
NODE_ENV=development

# ── Google Business reviews (optional) ──────────────────────────────
# Pull your Google reviews onto the site. Leave empty to disable.
# GOOGLE_API_KEY: a Google Maps "Places API" key (restrict it to Places API
#   + your server IP/referrers in Google Cloud Console).
# GOOGLE_PLACE_ID: your business's Place ID — find it at
#   https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_API_KEY=
GOOGLE_PLACE_ID=
# How long to cache Google's response, in minutes (avoids per-request billing).
GOOGLE_CACHE_TTL_MIN=360

# ── Owner SMS alerts via carrier email-to-SMS gateway (no Twilio) ──
# Texts you on every new booking. SMS_TO = <10-digit>@<carrier-gateway>.
# Boost Mobile: 8608950233@sms.myboostmobile.com
SMS_TO=
# SMTP account to send from (Gmail: smtp.gmail.com / 587 / your address / App Password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMS_FROM=
